generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

enum AccountType {
  CASH
  BANK
  EWALLET
  CREDIT_CARD
  OTHER
}

enum AccountPurpose {
  OPERATIONAL
  SAVINGS
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  name         String?
  passwordHash String
  accounts     Account[]
  categories   Category[]
  transactions Transaction[]
  budgets      Budget[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@map("users")
}

model Account {
  id                String         @id @default(uuid())
  userId            String
  name              String
  type              AccountType    @default(CASH)
  purpose           AccountPurpose @default(OPERATIONAL)
  balance           Decimal        @default(0) @db.Decimal(12, 2)
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions      Transaction[]  @relation("SourceAccountTransactions")
  incomingTransfers Transaction[]  @relation("DestinationAccountTransfers")
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([userId])
  @@map("accounts")
}

model Category {
  id           String          @id @default(uuid())
  userId       String
  name         String
  type         TransactionType @default(EXPENSE)
  color        String?
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  budgets      Budget[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([userId])
  @@map("categories")
}

model Transaction {
  id                   String          @id @default(uuid())
  userId               String
  type                 TransactionType
  amount               Decimal         @db.Decimal(12, 2)
  description          String?
  occurredAt           DateTime        @default(now())
  accountId            String
  destinationAccountId String?
  categoryId           String?
  user                 User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  account              Account         @relation("SourceAccountTransactions", fields: [accountId], references: [id], onDelete: Restrict)
  destinationAccount   Account?        @relation("DestinationAccountTransfers", fields: [destinationAccountId], references: [id], onDelete: Restrict)
  category             Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  @@index([userId])
  @@index([accountId])
  @@index([destinationAccountId])
  @@index([categoryId])
  @@index([occurredAt])
  @@map("transactions")
}

model Budget {
  id         String    @id @default(uuid())
  userId     String
  name       String
  amount     Decimal   @db.Decimal(12, 2)
  startsAt   DateTime
  endsAt     DateTime
  categoryId String?
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([userId])
  @@index([categoryId])
  @@index([startsAt, endsAt])
  @@map("budgets")
}
